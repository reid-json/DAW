<Component id="root"
          class="root"
          display="flex"
          flex-direction="column"
          align-items="stretch"
          width="1280"
          height="720"
          min-width="0"
          min-height="0">

  <Component id="headerContent"
             class="header"
             display="flex"
             flex-direction="row"
             align-items="center"
             flex-grow="0"
             flex-shrink="0"
             min-width="0"
             min-height="64"
             padding="10"
             row-gap="8"
             column-gap="8">

    <Button id="fileBtn"
            class="btn"
            width="72">
      <Text id="fileBtnLabel" text="File"/>
    </Button>

    <Button id="restartBtn"
            class="btn"
            width="80">
      <Text id="restartBtnLabel" text="Restart"/>
    </Button>

    <Button id="stopBtn"
            class="btn"
            width="72">
      <Text id="stopBtnLabel" text="Stop"/>
    </Button>

    <Button id="playBtn"
            class="btn btn-primary"
            width="72">
      <Text id="playBtnLabel" text="Play"/>
    </Button>

    <Button id="pauseBtn"
            class="btn"
            width="72">
      <Text id="pauseBtnLabel" text="Pause"/>
    </Button>

    <Button id="recordBtn"
            class="btn btn-record"
            width="90">
      <Text id="recordBtnLabel" text="Record"/>
    </Button>

    <Button id="pianoRollBtn"
            class="btn"
            width="96">
      <Text id="pianoRollBtnLabel" text="Piano Roll"/>
    </Button>

    <Button id="settingsBtn"
            class="btn"
            width="88">
      <Text id="settingsBtnLabel" text="Settings"/>
    </Button>

    <Component flex-grow="1"/>
  </Component>

  <Component id="bodyContent"
             display="flex"
             flex-direction="row"
             flex-grow="1"
             min-width="0"
             min-height="0">

    <Component id="sidebarContent"
               class="sidebar"
               display="flex"
               flex-direction="column"
               flex-grow="0"
               flex-shrink="0"
               width="240"
               min-width="180"
               max-width="420"
               padding="10"
               row-gap="10">

      <Button id="newTrackBtn"
              class="btn"
              width="140"
              height="32">
        <Text id="newTrackBtnLabel" text="New Track (5)"/>
      </Button>

      <Component id="trackList"
                 display="flex"
                 flex-direction="column"
                 row-gap="8"
                 flex-grow="1"
                 min-width="0"
                 min-height="0">
      </Component>
    </Component>

    <Component id="sidebarResizer"
               class="sidebar-resizer"
               width="10"
               flex-grow="0"
               flex-shrink="0"/>

    <Component id="clipSidebarContent"
           class="sidebar clipSidebar"
           display="flex"
           flex-direction="column"
           align-items="center"
           flex-grow="0"
           flex-shrink="0"
           width="220"
           min-width="160"
           max-width="320"
           padding="10"
           row-gap="10">

      <Button id="toggleClipSidebarBtn"
        class="btn clipToggleBtn"
        width="28"
        height="32">
        <Text id="toggleClipSidebarBtnLabel" text="&lt;"/>
      </Button>

      <Component id="clipBrowserHeader"
           display="flex"
           flex-direction="column"
           align-self="stretch"
           row-gap="4">
        <Text id="clipBrowserTitle"
              class="label"
              text="Recorded Clips"/>
        <Text id="clipBrowserSubTitle"
              class="secondary-label"
              text="Recent recordings"/>
      </Component>

      <Component id="clipSidebarSpacer"
                 height="4"/>

      <RecentClipsView id="clipList"
           align-self="stretch"
           flex-grow="1"
           min-width="0"
           min-height="0"/>
    </Component>

    <Component id="workspaceContent"
               class="workspace"
               display="flex"
               flex-direction="column"
               flex-grow="1"
               min-width="0"
               min-height="0"
               padding="12"
               row-gap="12">

      <Component id="timelinePanel"
                 class="panel"
                 display="flex"
                 flex-direction="column"
                 height="90"
                 padding="8">
        <TimelineView id="timelineView"
                      flex-grow="1"
                      min-width="0"
                      min-height="0"/>
      </Component>

      <Component id="arrangementPanel"
                 class="panel"
                 display="flex"
                 flex-direction="column"
                 flex-grow="1"
                 min-width="0"
                 min-height="0"
                 padding="16">
        <ArrangementView id="arrangementView"
                         flex-grow="1"
                         min-width="0"
                         min-height="0"/>
      </Component>
    </Component>
  </Component>
</Component>

<Component id="root"
          class="root"
          display="flex"
          flex-direction="column"
          align-items="stretch"
          width="1280"
          height="720"
          min-width="0"
          min-height="0">

  <Component id="headerContent"
             class="header"
             display="flex"
             flex-direction="column"
             flex-grow="0"
             flex-shrink="0"
             min-width="0"
             min-height="96"
             padding="10"
             row-gap="8">

    <Component id="headerTopRow"
               display="flex"
               flex-direction="row"
               align-items="center"
               min-width="0"
               min-height="28">

      <Component flex-grow="1"/>

      <Button id="monitorBtn"
              class="btn btn-monitor-off"
              width="124"
              height="28">
        <Text id="monitorBtnLabel" text="Monitor Off"/>
      </Button>
    </Component>

    <Component id="headerMainRow"
               display="flex"
               flex-direction="row"
               align-items="center"
               min-width="0"
               min-height="40"
               row-gap="8"
               column-gap="8">

      <Button id="fileBtn"
              class="btn"
              width="72">
        <Text id="fileBtnLabel" text="File"/>
      </Button>

      <Button id="restartBtn"
              class="btn"
              width="80">
        <Text id="restartBtnLabel" text="Restart"/>
      </Button>

      <Button id="stopBtn"
              class="btn"
              width="72">
        <Text id="stopBtnLabel" text="Stop"/>
      </Button>

      <Button id="playBtn"
              class="btn btn-primary"
              width="72">
        <Text id="playBtnLabel" text="Play"/>
      </Button>

      <Button id="pauseBtn"
              class="btn"
              width="72">
        <Text id="pauseBtnLabel" text="Pause"/>
      </Button>

      <Button id="recordBtn"
              class="btn btn-record"
              width="90">
        <Text id="recordBtnLabel" text="Record"/>
      </Button>

      <Button id="pianoRollBtn"
              class="btn"
              width="96">
        <Text id="pianoRollBtnLabel" text="Piano Roll"/>
      </Button>

      <Button id="settingsBtn"
              class="btn"
              width="88">
        <Text id="settingsBtnLabel" text="Settings"/>
      </Button>

      <Component flex-grow="1"/>
    </Component>
  </Component>

  <Component id="bodyContent"
             display="flex"
             flex-direction="row"
             flex-grow="1"
             min-width="0"
             min-height="0">

    <Component id="sidebarContent"
               class="sidebar"
               display="flex"
               flex-direction="column"
               flex-grow="0"
               flex-shrink="0"
               width="340"
               min-width="260"
               max-width="440"
               padding="10"
               row-gap="10">

      <Component id="masterSection"
                 class="mixer-shell"
                 align-self="stretch"
                 height="258"
                 min-width="0"
                 min-height="258">
        <MixerMasterView id="masterView"
                         flex-grow="1"
                         min-width="0"
                         min-height="0"/>
      </Component>

      <Component id="mixerPanel"
                 class="mixer-shell"
                 align-self="stretch"
                 flex-grow="1"
                 min-width="0"
                 min-height="0">

        <TrackListView id="trackList"
                       align-self="stretch"
                       flex-grow="1"
                       min-width="0"
                       min-height="0"/>
      </Component>

      <Button id="newTrackBtn"
              class="btn btn-mixer-add"
              width="170"
              height="44">
        <Text id="newTrackBtnLabel" text="Add Track +"/>
      </Button>
    </Component>

    <Component id="workspaceContent"
               class="workspace"
               display="flex"
               flex-direction="column"
               align-items="stretch"
               flex-grow="1"
               min-width="0"
               min-height="0"
               padding="0"
               row-gap="12">

      <Component id="timelinePanel"
                 class="panel"
                 display="flex"
                 flex-direction="column"
                 align-self="stretch"
                 height="90"
                 padding="8">
        <TimelineView id="timelineView"
                      flex-grow="1"
                      min-width="0"
                      min-height="0"/>
      </Component>

      <Component id="arrangementPanel"
                 class="panel"
                 display="flex"
                 flex-direction="column"
                 align-self="stretch"
                 flex-grow="1"
                 min-width="0"
                 min-height="0"
                 padding="16">
        <ArrangementView id="arrangementView"
                         flex-grow="1"
                         min-width="0"
                         min-height="0"/>
      </Component>
    </Component>

    <Component id="clipSidebarContent"
               class="sidebar clipSidebar"
               display="flex"
               flex-direction="column"
               align-items="center"
               flex-grow="0"
               flex-shrink="0"
               width="220"
               min-width="160"
               max-width="320"
               padding="10"
               row-gap="10">

      <Component id="clipBrowserHeader"
                 display="flex"
                 flex-direction="column"
                 align-self="stretch"
                 row-gap="4">
        <Text id="clipBrowserTitle"
              class="label"
              text="Recorded Clips"/>
        <Text id="clipBrowserSubTitle"
              class="secondary-label"
              text="Recent recordings"/>
      </Component>

      <Component id="clipSidebarSpacer"
                 height="4"/>

      <RecentClipsView id="clipList"
                       align-self="stretch"
                       flex-grow="1"
                       min-width="0"
                       min-height="0"/>
    </Component>
  </Component>
</Component>

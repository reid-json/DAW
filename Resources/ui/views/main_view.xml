<Component id="root"
          class="root"
          display="flex"
          flex-direction="column"
          align-items="stretch"
          width="1280"
          height="720"
          min-width="0"
          min-height="0">

  <Component id="headerContent"
             class="header"
             display="flex"
             flex-direction="column"
             flex-grow="0"
             flex-shrink="0"
             min-width="0"
             min-height="88"
             padding="10"
             row-gap="8">

    <Image id="headerSpice"
           width="1280"
           height="98"
           align-self="stretch"
           min-width="0"
           min-height="0"
           placement="fill"
           intercepts-mouse-clicks="false"/>

    <Component id="headerMainRow"
               display="flex"
               flex-direction="row"
               align-items="center"
               min-width="0"
               min-height="90"
               row-gap="8"
               column-gap="12">

      <Image id="headerLogo"
             width="90"
             height="90"
             min-width="90"
             min-height="90"
             placement="centred"/>

      <Button id="fileBtn"
              class="btn"
              width="72"
              justify-content="center"
              align-items="center">
        <Text id="fileBtnLabel" text="File"/>
      </Button>

      <Component flex-grow="1"/>

      <Component id="transportGroup"
                 display="flex"
                 flex-direction="row"
                 align-items="center"
                 justify-content="center"
                 column-gap="12">
        <Button id="restartBtn"
                class="btn"
                width="80">
          <Text id="restartBtnLabel" text="Restart"/>
        </Button>

        <Button id="playBtn"
                class="btn btn-primary"
                width="72">
          <Text id="playBtnLabel" text="Play"/>
        </Button>

        <Button id="pauseBtn"
                class="btn"
                width="72">
          <Text id="pauseBtnLabel" text="Pause"/>
        </Button>

        <Button id="recordBtn"
                class="btn btn-record"
                width="90">
          <Text id="recordBtnLabel" text="Record"/>
        </Button>

        <Button id="pianoRollBtn"
                class="btn"
                width="96">
          <Text id="pianoRollBtnLabel" text="Piano Roll"/>
        </Button>
      </Component>

      <TempoControlView id="tempoControlView"
                        width="260"
                        min-width="260"
                        max-width="260"/>

      <Button id="settingsBtn"
              class="btn"
              width="88">
        <Text id="settingsBtnLabel" text="Settings"/>
      </Button>
    </Component>
  </Component>

  <Component id="bodyContent"
             display="flex"
             flex-direction="row"
             flex-grow="1"
             min-width="0"
             min-height="0">

    <Component id="workspaceContent"
               class="workspace"
               display="flex"
               flex-direction="column"
               align-items="stretch"
               flex-grow="1"
               min-width="0"
               min-height="0"
               padding="0"
               row-gap="0">

      <Component id="trackArea"
                 display="flex"
                 flex-direction="row"
                 align-self="stretch"
                 flex-grow="1"
                 min-width="0"
                 min-height="0">

        <!-- Mixer strips: master row 0, then track rows -->
        <TrackListView id="trackList"
                       min-width="0"
                       min-height="0"/>

        <!-- Timeline ruler + arrangement stacked vertically -->
        <Component id="timelineArrangementStack"
                   display="flex"
                   flex-direction="column"
                   flex-grow="1"
                   min-width="0"
                   min-height="0">

          <Component id="timelinePanel"
                     class="panel"
                     display="flex"
                     flex-direction="column"
                     align-self="stretch"
                     min-width="0"
                     min-height="0"
                     padding="8">
            <TimelineView id="timelineView"
                          flex-grow="1"
                          min-width="0"
                          min-height="0"/>
          </Component>

          <Component id="arrangementPanel"
                     class="panel"
                     display="flex"
                     flex-direction="column"
                     align-self="stretch"
                     flex-grow="1"
                     min-width="0"
                     min-height="0"
                     padding="0">
            <ArrangementView id="arrangementView"
                             flex-grow="1"
                             min-width="0"
                             min-height="0"/>
          </Component>
        </Component>
      </Component>

      <!-- Right sidebar: clip browser -->
    </Component>

    <Component id="clipSidebarContent"
               class="sidebar clipSidebar"
               display="flex"
               flex-direction="column"
               align-items="center"
               flex-grow="0"
               flex-shrink="0"
               width="220"
               min-width="160"
               max-width="320"
               padding="10"
               row-gap="10">

      <Image id="bodySpiceSidebar"
             width="220"
             height="622"
             align-self="stretch"
             min-width="0"
             min-height="0"
             placement="fill"
             intercepts-mouse-clicks="false"/>

      <Text id="clipBrowserTitle"
            class="label sidebarTitle"
            align-self="stretch"
            text="Saved Clips &amp; Patterns"/>

      <Component id="clipSidebarSpacer"
                 height="4"/>

      <RecentClipsView id="clipList"
                       align-self="stretch"
                       flex-grow="1"
                       min-width="0"
                       min-height="0"/>

    </Component>
  </Component>
</Component>
